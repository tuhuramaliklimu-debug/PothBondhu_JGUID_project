<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme -->
    <style name="Theme.PothBondhu" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/navy_primary</item>
        <item name="colorPrimaryVariant">@color/navy_dark</item>
        <item name="colorOnPrimary">@color/beige_light</item>
        <item name="colorSecondary">@color/beige_primary</item>
        <item name="colorSecondaryVariant">@color/beige_dark</item>
        <item name="colorOnSecondary">@color/navy_dark</item>
        <item name="android:statusBarColor">@color/navy_dark</item>
        <item name="android:windowBackground">@color/beige_light</item>
    </style>

    <!-- Service Button Style (without layout attributes) -->
    <style name="ServiceButton" parent="Widget.Material3.Button">
        <item name="android:textSize">14sp</item>
        <item name="android:gravity">center</item>
        <item name="android:background">@drawable/button_background</item>
        <item name="android:textColor">@color/beige_light</item>
        <item name="android:padding">12dp</item>
        <item name="android:minHeight">80dp</item>
        <item name="android:maxWidth">120dp</item>
        <item name="android:lines">2</item>
        <item name="android:maxLines">2</item>
    </style>
</resources>