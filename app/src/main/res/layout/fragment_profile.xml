<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/beige_light"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingBottom="32dp">

        <!-- ===== SECTION 1: PROFILE HEADER ===== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:background="@drawable/header_gradient">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/avatarInitials"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:text="AN"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/navy_primary"
                        android:gravity="center"
                        android:background="@drawable/avatar_large"
                        android:layout_centerHorizontal="true" />
                </RelativeLayout>

                <TextView
                    android:id="@+id/profileName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Anisa Tahsin Nisa"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/beige_light"
                    android:layout_gravity="center_horizontal" />

                <TextView
                    android:id="@+id/profileLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dhaka, Bangladesh"
                    android:textSize="14sp"
                    android:textColor="@color/beige_light"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/editProfileBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="EDIT PROFILE"
                    android:textSize="12sp"
                    android:backgroundTint="@color/beige_light"
                    android:textColor="@color/navy_primary"
                    android:layout_gravity="center_horizontal" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/contactCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="@color/beige_light" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Contacts"
                            android:textSize="12sp"
                            android:textColor="@color/beige_light" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="40dp"
                        android:background="@color/beige_light"
                        android:alpha="0.3" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/alertCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="12"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="@color/beige_light" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Alerts Sent"
                            android:textSize="12sp"
                            android:textColor="@color/beige_light" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== SECTION 2: MEDICAL INFORMATION ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MEDICAL INFORMATION"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/navy_dark"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="This information is shared during SOS alerts."
            android:textSize="11sp"
            android:textColor="@color/navy_light"
            android:layout_marginBottom="12dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- Blood Group -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="BLOOD GROUP"
                            android:textSize="11sp"
                            android:textColor="@color/navy_light" />

                        <TextView
                            android:id="@+id/bloodGroupValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Not set"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/navy_dark" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/editBloodGroupBtn"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="EDIT"
                        android:textSize="11sp"
                        android:backgroundTint="@color/beige_primary"
                        android:textColor="@color/navy_primary" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/beige_dark" />

                <!-- Allergies -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ALLERGIES"
                            android:textSize="11sp"
                            android:textColor="@color/navy_light" />

                        <TextView
                            android:id="@+id/allergiesValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="None"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/navy_dark" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/editAllergiesBtn"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="EDIT"
                        android:textSize="11sp"
                        android:backgroundTint="@color/beige_primary"
                        android:textColor="@color/navy_primary" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== SECTION 3: ADDITIONAL MEDICAL INFO ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ADDITIONAL MEDICAL INFO"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/navy_dark"
            android:layout_marginBottom="8dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Current Medications"
                            android:textSize="11sp"
                            android:textColor="@color/navy_light" />

                        <TextView
                            android:id="@+id/medicationsValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="None"
                            android:textSize="14sp"
                            android:textColor="@color/navy_dark" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/editMedsBtn"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="EDIT"
                        android:textSize="11sp"
                        android:backgroundTint="@color/beige_primary"
                        android:textColor="@color/navy_primary" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/beige_dark" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Medical Conditions"
                            android:textSize="11sp"
                            android:textColor="@color/navy_light" />

                        <TextView
                            android:id="@+id/conditionsValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="None"
                            android:textSize="14sp"
                            android:textColor="@color/navy_dark" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/editConditionsBtn"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="EDIT"
                        android:textSize="11sp"
                        android:backgroundTint="@color/beige_primary"
                        android:textColor="@color/navy_primary" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== SECTION 4: EMERGENCY CONTACTS ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EMERGENCY CONTACTS"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/navy_dark"
            android:layout_marginBottom="8dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:id="@+id/contactsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp" />

        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/addContactBtn"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="24dp"
            android:text="+ Add Emergency Contact"
            android:textSize="14sp"
            android:textStyle="bold"
            android:backgroundTint="@color/navy_primary"
            android:textColor="@color/beige_light" />

        <!-- ===== SECTION 5: SAFETY SETTINGS (NEW) ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SAFETY SETTINGS"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/navy_dark"
            android:layout_marginBottom="8dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- Crash Detection -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Crash Detection"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/navy_dark" />

                        <TextView
                            android:id="@+id/crashStatusText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Enabled"
                            android:textSize="12sp"
                            android:textColor="#4CAF50" />
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/crashDetectionSwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/beige_dark" />

                <!-- Detection Sensitivity -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Detection Sensitivity"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/navy_dark" />

                    <TextView
                        android:id="@+id/sensitivityValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Medium (8G)"
                        android:textSize="12sp"
                        android:textColor="@color/navy_light"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="8dp" />

                    <SeekBar
                        android:id="@+id/sensitivitySeekBar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="12"
                        android:progress="8" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Low (4G)"
                            android:textSize="10sp"
                            android:textColor="@color/navy_light" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Medium (8G)"
                            android:textSize="10sp"
                            android:textColor="@color/navy_light"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="High (12G)"
                            android:textSize="10sp"
                            android:textColor="@color/navy_light"
                            android:gravity="end" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/beige_dark" />

                <!-- SOS Method -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SOS Method"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/navy_dark" />

                        <TextView
                            android:id="@+id/sosMethodValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="WhatsApp + SMS"
                            android:textSize="12sp"
                            android:textColor="@color/navy_light" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/editSosMethodBtn"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="Change"
                        android:textSize="11sp"
                        android:backgroundTint="@color/beige_primary"
                        android:textColor="@color/navy_primary" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/beige_dark" />

                <!-- Background Location -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Background Location"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/navy_dark" />

                        <TextView
                            android:id="@+id/locationStatusText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Always On"
                            android:textSize="12sp"
                            android:textColor="#4CAF50" />
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/locationSwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== SECTION 6: ACCOUNT ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ACCOUNT"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/navy_dark"
            android:layout_marginBottom="8dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Email Address"
                        android:textSize="12sp"
                        android:textColor="@color/navy_light" />

                    <TextView
                        android:id="@+id/emailValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="anisa@example.com"
                        android:textSize="14sp"
                        android:textColor="@color/navy_dark" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/beige_dark" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Phone Number"
                        android:textSize="12sp"
                        android:textColor="@color/navy_light" />

                    <TextView
                        android:id="@+id/phoneValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+880 1712 345 678"
                        android:textSize="14sp"
                        android:textColor="@color/navy_dark" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/beige_dark" />

                <TextView
                    android:id="@+id/changePassword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Change Password →"
                    android:textSize="14sp"
                    android:textColor="@color/navy_primary"
                    android:paddingVertical="8dp"
                    android:clickable="true" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== SECTION 7: APP & PRIVACY ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="APP &amp; PRIVACY"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/navy_dark"
            android:layout_marginBottom="8dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Language"
                        android:textSize="14sp"
                        android:textColor="@color/navy_dark" />

                    <TextView
                        android:id="@+id/languageValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="English"
                        android:textSize="14sp"
                        android:textColor="@color/navy_light" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/beige_dark" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="App Version"
                        android:textSize="14sp"
                        android:textColor="@color/navy_dark" />

                    <TextView
                        android:id="@+id/appVersion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1.2.0"
                        android:textSize="14sp"
                        android:textColor="@color/navy_light" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/beige_dark" />

                <TextView
                    android:id="@+id/privacyPolicy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Privacy Policy →"
                    android:textSize="14sp"
                    android:textColor="@color/navy_primary"
                    android:paddingVertical="8dp"
                    android:clickable="true" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/beige_dark" />

                <TextView
                    android:id="@+id/termsOfService"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Terms of Service →"
                    android:textSize="14sp"
                    android:textColor="@color/navy_primary"
                    android:paddingVertical="8dp"
                    android:clickable="true" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== SECTION 8: DANGER ZONE ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DANGER ZONE"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#E74C3C"
            android:layout_marginBottom="8dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFF5F5">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/downloadData"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📥 Download My Data"
                    android:textSize="14sp"
                    android:textColor="#E74C3C"
                    android:paddingVertical="12dp"
                    android:clickable="true" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#FFCDD2" />

                <TextView
                    android:id="@+id/deleteAccount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🗑️ Delete Account"
                    android:textSize="14sp"
                    android:textColor="#E74C3C"
                    android:paddingVertical="12dp"
                    android:clickable="true" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== SECTION 9: SOS BUTTON ===== -->
        <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
            android:id="@+id/profileSosFab"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            android:text="SOS"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="18sp"
            app:icon="@android:drawable/ic_dialog_alert"
            app:backgroundTint="#E74C3C"
            app:iconTint="@android:color/white" />

    </LinearLayout>
</ScrollView>