<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/beige_light">

    <!-- Top Bar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/navy_primary"
        app:titleTextColor="@color/beige_light"
        app:title="PothBondhu" />

    <!-- SOS Button -->
    <Button
        android:id="@+id/sosButton"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="16dp"
        android:text="SOS"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:background="@drawable/sos_button_background" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="Your Friend on the Road"
        android:textColor="@color/navy_light"
        android:layout_marginBottom="16dp" />

    <!-- Map View -->
    <org.osmdroid.views.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:layout_margin="8dp" />

    <!-- Emergency Services Label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:text="Emergency Services"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/navy_dark" />

    <!-- Emergency Services Grid -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:rowCount="2"
        android:columnCount="3"
        android:padding="8dp">

        <Button
            android:id="@+id/btnHospitals"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            android:text="🏥\nHospitals"
            android:textSize="14sp"
            android:gravity="center"
            android:background="@drawable/button_background"
            android:textColor="@color/beige_light"
            android:padding="8dp"
            android:lines="2"
            android:maxLines="2" />

        <Button
            android:id="@+id/btnPolice"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            android:text="🚓\nPolice"
            android:textSize="14sp"
            android:gravity="center"
            android:background="@drawable/button_background"
            android:textColor="@color/beige_light"
            android:padding="8dp"
            android:lines="2"
            android:maxLines="2" />

        <Button
            android:id="@+id/btnBloodBank"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            android:text="🩸\nBlood Bank"
            android:textSize="14sp"
            android:gravity="center"
            android:background="@drawable/button_background"
            android:textColor="@color/beige_light"
            android:padding="8dp"
            android:lines="2"
            android:maxLines="2" />

        <Button
            android:id="@+id/btnFuel"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            android:text="⛽\nFuel Station"
            android:textSize="14sp"
            android:gravity="center"
            android:background="@drawable/button_background"
            android:textColor="@color/beige_light"
            android:padding="8dp"
            android:lines="2"
            android:maxLines="2" />

        <Button
            android:id="@+id/btnMechanic"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            android:text="🔧\nMechanic"
            android:textSize="14sp"
            android:gravity="center"
            android:background="@drawable/button_background"
            android:textColor="@color/beige_light"
            android:padding="8dp"
            android:lines="2"
            android:maxLines="2" />

        <Button
            android:id="@+id/btnRide"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            android:text="🚗\nBook Ride"
            android:textSize="14sp"
            android:gravity="center"
            android:background="@drawable/button_background"
            android:textColor="@color/beige_light"
            android:padding="8dp"
            android:lines="2"
            android:maxLines="2" />

    </GridLayout>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:menu="@menu/bottom_nav_menu" />

</LinearLayout>